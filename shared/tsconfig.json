{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",

    "rootDir": ".",
    "outDir": "dist",

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "strict": true,
    "skipLibCheck": true,

    "moduleResolution": "NodeNext",
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["dist", "node_modules"]
}