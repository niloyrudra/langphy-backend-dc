# ═══════════════════════════════════════════════════════════════════════════════
# Langphy Caddyfile
# Replace api.langphy.com with your actual domain.
# Caddy handles TLS automatically via Let's Encrypt — no cert config needed.
#
# Timeouts are generous for:
#   - Speech: audio upload + Whisper transcription (~30s)
#   - NLP: spaCy analysis (~5s)
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# Langphy Caddyfile
#
# LOCAL TESTING: uses :80 (plain HTTP, no TLS, no domain needed)
# PRODUCTION (Railway): change :80 to api.langphy.com and restore ports 80/443
#                       in docker-compose.yml
# ═══════════════════════════════════════════════════════════════════════════════

# Railway handles TLS externally.
# Caddy must NOT redirect to HTTPS — it only proxies plain HTTP.
# auto_https off disables Caddy's automatic HTTPS redirect.
# {
#     auto_https off
# }

# # :80 { # For Development
