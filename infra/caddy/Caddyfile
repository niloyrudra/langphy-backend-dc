# Langphy Caddyfile — Railway Production
# ─────────────────────────────────────────────────────────────────────────
# This uses Railway reference variables for upstream addresses.
# Each upstream is set as an env var in the Caddy service variables.
# Pattern: SERVICE_HOST=${{service-name.RAILWAY_PRIVATE_DOMAIN}}
#          SERVICE_PORT=${{service-name.PORT}}
#
# IMPORTANT: Every backend service must have PORT set as a fixed variable.
# ─────────────────────────────────────────────────────────────────────────

{
    auto_https off
    admin off
    persist_config off

    servers {
        trusted_proxies static private_ranges
    }
}

:{$PORT} {

    log {
        output stdout
        format json
    }

    handle /api/users/* {
        reverse_proxy {$AUTH_HOST}:{$AUTH_PORT}
    }

    handle /api/events* {
        reverse_proxy {$GATEWAY_HOST}:{$GATEWAY_PORT}
    }
    # handle /api/events/* {
    #     reverse_proxy {$GATEWAY_HOST}:{$GATEWAY_PORT}
    # }

    handle /api/streaks/* {
        reverse_proxy {$STREAKS_HOST}:{$STREAKS_PORT}
    }

    handle /api/progress/* {
        reverse_proxy {$PROGRESS_HOST}:{$PROGRESS_PORT}
    }

    handle /api/vocabulary/* {
        reverse_proxy {$PROGRESS_HOST}:{$PROGRESS_PORT}
    }

    handle /api/performance/* {
        reverse_proxy {$PERFORMANCE_HOST}:{$PERFORMANCE_PORT}
    }

    handle /api/profile/* {
        reverse_proxy {$PROFILE_HOST}:{$PROFILE_PORT}
    }

    handle /api/settings/* {
        reverse_proxy {$SETTINGS_HOST}:{$SETTINGS_PORT}
    }

    handle /api/notification/* {
        reverse_proxy {$NOTIFICATION_HOST}:{$NOTIFICATION_PORT}
    }

    handle /api/category/* {
        reverse_proxy {$CATEGORY_HOST}:{$CATEGORY_PORT}
    }

    handle /api/unit/* {
        reverse_proxy {$UNIT_HOST}:{$UNIT_PORT}
    }

    handle /api/practices/* {
        reverse_proxy {$PRACTICE_HOST}:{$PRACTICE_PORT}
    }

    handle /api/quizzes/* {
        reverse_proxy {$QUIZ_HOST}:{$QUIZ_PORT}
    }

    handle /api/speaking/* {
        reverse_proxy {$SPEAKING_HOST}:{$SPEAKING_PORT}
    }

    handle /api/reading/* {
        reverse_proxy {$READING_HOST}:{$READING_PORT}
    }

    handle /api/writing/* {
        reverse_proxy {$WRITING_HOST}:{$WRITING_PORT}
    }

    handle /api/listening/* {
        reverse_proxy {$LISTENING_HOST}:{$LISTENING_PORT}
    }

    handle /api/nlp/* {
        reverse_proxy {$NLP_HOST}:{$NLP_PORT} {
            transport http {
                read_timeout 30s
                write_timeout 30s
            }
        }
    }

    handle /api/speech/* {
        request_body {
            max_size 50MB
        }
        reverse_proxy {$SPEECH_API_HOST}:{$SPEECH_API_PORT} {
            transport http {
                read_timeout 120s
                write_timeout 120s
            }
        }
    }

    encode gzip
}









# Langphy Caddyfile — Railway Production
# ─────────────────────────────────────────────────────────────────────────
# KEY POINTS:
# 1. {$PORT} — Railway injects PORT env var, Caddy must listen on it
# 2. auto_https off — Railway handles TLS, Caddy must NOT redirect to HTTPS
# 3. trusted_proxies — trust Railway's edge proxy for real IP forwarding
# 4. http:// prefix on upstream — forces plain HTTP, no TLS attempt
# 5. Hardcoded ports match what each service actually listens on
# ─────────────────────────────────────────────────────────────────────────

# {
#     auto_https off
#     admin off

#     servers {
#         trusted_proxies static private_ranges
#     }
# }

# :{$PORT} {

#     log {
#         output stdout
#         format json
#     }

#     # ── Auth ────────────────────────────────────────────────────────────
#     handle /api/users/* {
#         reverse_proxy http://auth.railway.internal:3000
#     }

#     # ── Gateway ─────────────────────────────────────────────────────────
#     handle /api/events/* {
#         reverse_proxy http://gateway.railway.internal:3009
#     }

#     # ── User data services ───────────────────────────────────────────────
#     handle /api/streaks/* {
#         reverse_proxy http://streaks.railway.internal:3001
#     }

#     handle /api/progress/* {
#         reverse_proxy http://progress.railway.internal:3002
#     }

#     handle /api/vocabulary/* {
#         reverse_proxy http://progress.railway.internal:3002
